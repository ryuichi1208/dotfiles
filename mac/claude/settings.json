{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "env": {
    "ANTHROPIC_CUSTOM_HEADERS": "[object Object]",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "DISABLE_TELEMETRY": "false"
  },
  "permissions": {
    "allow": [
      "Read(~/.zshrc)",
      "List(*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(bat:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(uv sync)",
      "Bash(uv pip list)",
      "Bash(go version)",
      "Bash(go env)",
      "Bash(go mod tidy)",
      "Bash(go list:*)",
      "Bash(perl --version)",
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(actionlint:*)",
      "Bash(mkdir -p ./:*)",
      "Bash(rm hello.py)",
      "Bash(find ./:*)",
      "Bash(make lint:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run pytest:*)",
      "Bash(git status)",
      "Bash(git -C:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view --json name,owner:*)",
      "Bash(gh repo view --json description,readme:*)",
      "Bash(gh api -X GET /repos/:owner/:repo/commits:*)",
      "Bash(gh api -X GET /repos/:owner/:repo/pulls:*)",
      "Bash(gh api -X GET /repos/:owner/:repo/issues:*)",
      "Bash(gh api -X GET /repos/:owner/:repo:*)",
      "Bash(gh api -X GET /users/:username:*)",
      "Bash(gh api -X GET /search/code?q=:query:*)",
      "Bash(gh api -X GET /search/issues?q=:query:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:docs.aws.amazon.com)",
      "Web Search(*)"
    ],
    "deny": [
      "Write(~/.zshrc)",
      "Write(~/.vimrc)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754103918075
  },
  "autoUpdates": true
}
